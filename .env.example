APP_ENV=dev

DOCKERHUB_NAMESPACE=duclm2006
IMAGE_TAG=latest

POSTGRES_DB=deepface_access
POSTGRES_USER=deepface
POSTGRES_PASSWORD=deepface
DATABASE_URL=postgresql://deepface:deepface@database:5432/deepface_access

REDIS_URL=redis://redis:6379/0
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174,http://localhost:8080,http://127.0.0.1:8080

AUTH_SECRET_KEY=deepface-access-dev-secret
ACCESS_TOKEN_EXPIRE_MINUTES=1440

SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=admin123
SEED_USER_USERNAME=user
SEED_USER_PASSWORD=user123

VITE_API_BASE_URL=http://localhost:8000
VITE_USER_BASE_PATH=/
VITE_ADMIN_BASE_PATH=/admin/

DEEPFACE_MODEL_NAME=Facenet512
DEEPFACE_DETECTOR_BACKEND=opencv
DEEPFACE_ENFORCE_DETECTION=true
DEEPFACE_ALIGN=true
DEEPFACE_NORMALIZATION=base
DEEPFACE_MATCH_THRESHOLD=0.70
DEEPFACE_ANTI_SPOOFING=false

MINIO_ENDPOINT=minio:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=deepface-images
MINIO_SECURE=false

QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=deepface_embeddings

PROMETHEUS_PORT=9090
ALERTMANAGER_PORT=9093
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
NGINX_PORT=8080
